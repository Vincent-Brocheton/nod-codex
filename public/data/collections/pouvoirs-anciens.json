    {
      "id": "38388b48-e48e-8063-9e67-e3237f433b9c",
      "slug": "deni",
      "title": "Déni",
      "notionUrl": "https://app.notion.com/p/D-ni-38388b48e48e80639e67e3237f433b9c",
      "lastEditedTime": "2026-06-29T13:29:00.000Z",
      "properties": {
        "Niveau": {
          "type": "number",
          "value": 6
        },
        "Jet d'attaque": {
          "type": "multi_select",
          "value": []
        },
